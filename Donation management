#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <time.h>

#define MAX 100

struct Donor {
    int id;
    char name[50];
    char type[20];
    float amount;
    int quantity;       
    char date[15];
};

int getNextID();
int isValidName(char name[]);
int validateDate(int d, int m, int y);
void autoGenerateDate(char date[]);

void addDonation(struct Donor donors[], int *count);
void viewDonations(struct Donor donors[], int count);
void searchDonation(struct Donor donors[], int count);
void donorDetails(struct Donor donors[], int count);
void deleteDonation(struct Donor donors[], int *count);
void deleteMultiple(struct Donor donors[], int *count);
void totalSummary(struct Donor donors[], int count);

void saveToFile(struct Donor donors[], int count);
void loadFromFile(struct Donor donors[], int *count);


int getNextID() {
    int id = 1;
    FILE *fp = fopen("donor_id.txt", "r");

    if (fp != NULL) {
        fscanf(fp, "%d", &id);
        fclose(fp);
    }

    fp = fopen("donor_id.txt", "w");
    fprintf(fp, "%d", id + 1);
    fclose(fp);

    return id;
}


int isValidName(char name[]) {
    for(int i=0; name[i]; i++)
        if(!isalpha(name[i]) && name[i] != ' ')
            return 0;
    return 1;
}


int validateDate(int d, int m, int y){
    if (y < 2020 || y > 2030) return 0;
    if(m < 1 || m > 12) return 0;

    int daysInMonth[] = {31,28,31,30,31,30,31,31,30,31,30,31};

    if((y % 4 == 0 && y % 100 != 0) || (y % 400 == 0))
        daysInMonth[1] = 29;

    return (d >= 1 && d <= daysInMonth[m - 1]);
}

void autoGenerateDate(char date[]) {
    time_t t = time(NULL);
    struct tm *tm = localtime(&t);

    sprintf(date,"%02d-%02d-%04d",
            tm->tm_mday,
            tm->tm_mon + 1,
            tm->tm_year + 1900);
}


void addDonation(struct Donor donors[], int *count) {

    int idx = *count;
    donors[idx].id = getNextID();
    printf("\nGenerated Donor ID: D%03d\n", donors[idx].id);

    // NAME
    while(1){
        printf("Enter Donor Name: ");
        fgets(donors[idx].name,50,stdin);
        donors[idx].name[strcspn(donors[idx].name,"\n")] = '\0';
        if(isValidName(donors[idx].name)) break;
        printf("Invalid name! Only alphabets & spaces allowed.\n");
    }

    // TYPE
    printf("Donation Types: money | raw food | cooked food | clothes\n");
    printf("Enter Type: ");
    fgets(donors[idx].type,20,stdin);
    donors[idx].type[strcspn(donors[idx].type,"\n")] = '\0';

    // ---- MONEY ----
    if(strcmp(donors[idx].type,"money")==0){
        do {
            printf("Enter Money Amount: ");
            scanf("%f",&donors[idx].amount);
            while(getchar()!='\n');
            if(donors[idx].amount < 0)
                printf("? Amount cannot be negative!\n");
        } while(donors[idx].amount < 0);

        donors[idx].quantity = 0;
    }

    // ---- RAW FOOD ----
    else if(strcmp(donors[idx].type,"raw food")==0){
        do{
            printf("Enter Quantity (kg): ");
            scanf("%d",&donors[idx].quantity);
            while(getchar()!='\n');
            if(donors[idx].quantity < 0)
                printf("? Quantity cannot be negative!\n");
        } while(donors[idx].quantity < 0);

        donors[idx].amount = 0;
    }

    // ---- COOKED FOOD ----
    else if(strcmp(donors[idx].type,"cooked food")==0){
        do{
            printf("Enter number of persons cooked food can serve: ");
            scanf("%d",&donors[idx].quantity);
            while(getchar()!='\n');
            if(donors[idx].quantity < 0)
                printf("? Persons cannot be negative!\n");
        } while(donors[idx].quantity < 0);

        donors[idx].amount = 0;
    }

    // ---- CLOTHES ----
    else if(strcmp(donors[idx].type,"clothes")==0){
        do{
            printf("Enter number of clothes: ");
            scanf("%d",&donors[idx].quantity);
            while(getchar()!='\n');
            if(donors[idx].quantity < 0)
                printf("? Number of clothes cannot be negative!\n");
        } while(donors[idx].quantity < 0);

        donors[idx].amount = 0;
    }

    else{
        printf("Invalid type! Cancelling.\n");
        return;
    }

    // DATE
    char opt;
    int dd,mm,yy;
    printf("Use Auto Date? (Y/N): ");
    scanf("%c",&opt);
    while(getchar()!='\n');

    if(opt=='Y'||opt=='y'){
        autoGenerateDate(donors[idx].date);
    } else {
        while(1){
            printf("Enter Date (DD-MM-YYYY): ");
            scanf("%d-%d-%d",&dd,&mm,&yy);
            while(getchar()!='\n');

            if(validateDate(dd,mm,yy)){
                sprintf(donors[idx].date,"%02d-%02d-%04d",dd,mm,yy);
                break;
            }
            else printf("Invalid Date! Try again.\n");
        }
    }

    (*count)++;
    printf("Donation Added Successfully!\n");
}


void viewDonations(struct Donor donors[], int count) {
    if(count==0){ printf("No records.\n"); return; }

    for(int i=0; i<count; i++){
        printf("\nID: D%03d\nName: %s\nType: %s\nAmount: %.2f\nQuantity: %d\nDate: %s\n",
            donors[i].id,
            donors[i].name,
            donors[i].type,
            donors[i].amount,
            donors[i].quantity,
            donors[i].date);
    }
}


void searchDonation(struct Donor donors[], int count) {
    char name[50];
    printf("Enter Name: ");
    fgets(name,50,stdin);
    name[strcspn(name,"\n")] = '\0';

    for(int i=0;i<count;i++){
        if(strcmp(name,donors[i].name)==0){
            printf("\nFOUND!\nID: D%03d\nType: %s\nAmount: %.2f\nQty: %d\nDate: %s\n",
                donors[i].id,
                donors[i].type,
                donors[i].amount,
                donors[i].quantity,
                donors[i].date);
            return;
        }
    }
    printf("Not found.\n");
}


void donorDetails(struct Donor donors[], int count) {
    int id;
    printf("Enter Donor ID number: ");
    scanf("%d",&id);
    while(getchar()!='\n');

    for(int i=0;i<count;i++){
        if(donors[i].id==id){
            printf("\nFOUND!\nID: D%03d\nName: %s\nType: %s\nAmount: %.2f\nQty: %d\nDate: %s\n",
                donors[i].id,
                donors[i].name,
                donors[i].type,
                donors[i].amount,
                donors[i].quantity,
                donors[i].date);
            return;
        }
    }
    printf("Not found.\n");
}


void deleteDonation(struct Donor donors[], int *count) {
    int id;
    printf("Enter ID to delete: ");
    scanf("%d",&id);
    while(getchar()!='\n');

    int pos = -1;

    for (int i = 0; i < *count; i++) {
        if (donors[i].id == id) { pos = i; break; }
    }

    if (pos == -1) {
        printf("Record Not Found.\n");
        return;
    }

    for (int i = pos; i < *count - 1; i++)
        donors[i] = donors[i+1];

    (*count)--;

    printf("Deleted!\n");
}


void deleteMultiple(struct Donor donors[], int *count) {
    char line[200];
    int ids[50], n = 0;

    printf("Enter IDs to delete (space separated): ");
    fgets(line, sizeof(line), stdin);

    char *token = strtok(line, " ");
    while(token != NULL) {
        ids[n++] = atoi(token);
        token = strtok(NULL, " ");
    }

    int deleted = 0;

    for(int k=0; k<n; k++) {
        int id = ids[k];
        int pos = -1;

        for(int i=0; i<*count; i++){
            if(donors[i].id == id){
                pos = i;
                break;
            }
        }

        if(pos != -1){
            for(int i=pos; i<*count-1; i++){
                donors[i] = donors[i+1];
            }
            (*count)--;
            deleted++;
        }
    }

    printf("\nDeleted %d records.\n", deleted);
}


void totalSummary(struct Donor donors[], int count) {
    float money=0;
    int raw=0,cooked=0,clothes=0;

    for(int i=0;i<count;i++){
        if(strcmp(donors[i].type,"money")==0)
            money+=donors[i].amount;
        else if(strcmp(donors[i].type,"raw food")==0)
            raw+=donors[i].quantity;
        else if(strcmp(donors[i].type,"cooked food")==0)
            cooked+=donors[i].quantity;
        else if(strcmp(donors[i].type,"clothes")==0)
            clothes+=donors[i].quantity;
    }

    printf("\n------ SUMMARY ------\n");
    printf("Total Money: %.2f\n",money);
    printf("Raw Food: %d kg\n",raw);
    printf("Cooked Food: %d persons\n",cooked);
    printf("Clothes: %d\n",clothes);
}


void saveToFile(struct Donor donors[], int count) {
    FILE *fp=fopen("donations.csv","w");
    if(!fp){ printf("Error opening file.\n"); return; }

    fprintf(fp,"ID,Name,Type,Amount,Quantity,Date\n");

    for(int i=0;i<count;i++){
        fprintf(fp,"%d,%s,%s,%.2f,%d,%s\n",
            donors[i].id,
            donors[i].name,
            donors[i].type,
            donors[i].amount,
            donors[i].quantity,
            donors[i].date);
    }

    fclose(fp);
    printf("Data Saved!\n");
}


void loadFromFile(struct Donor donors[], int *count) {
    FILE *fp=fopen("donations.csv","r");
    if(!fp){ *count=0; return; }

    char line[200];
    fgets(line,200,fp); // skip header
    *count=0;

    while(fgets(line,200,fp)){
        sscanf(line," %d , %49[^,] , %19[^,] , %f , %d , %14s",
            &donors[*count].id,
            donors[*count].name,
            donors[*count].type,
            &donors[*count].amount,
            &donors[*count].quantity,
            donors[*count].date);

        (*count)++;
    }

    fclose(fp);
}


int main() {

    struct Donor donors[MAX];
    int count = 0, choice;

    loadFromFile(donors, &count);

    while (1) {
        printf("\n----- DONATION MANAGEMENT SYSTEM -----\n");
        printf("1. Add Donation\n");
        printf("2. View All Donations\n");
        printf("3. Search by Name\n");
        printf("4. Search by ID\n");
        printf("5. Delete Donation\n");
        printf("6. Delete Multiple IDs\n");
        printf("7. Total Summary\n");
        printf("8. Save to File\n");
        printf("9. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);
        while (getchar()!='\n');

        switch(choice) {
            case 1: addDonation(donors, &count); break;
            case 2: viewDonations(donors, count); break;
            case 3: searchDonation(donors, count); break;
            case 4: donorDetails(donors, count); break;
            case 5: deleteDonation(donors, &count); break;
            case 6: deleteMultiple(donors, &count); break;
            case 7: totalSummary(donors, count); break;
            case 8: saveToFile(donors, count); break;
            case 9: saveToFile(donors, count); return 0;
            default: printf("Invalid Choice!\n");
        }
    }
}
